# Application Configuration
ADAPTIX_INSIGHT_APP_NAME=adaptix-insight
ADAPTIX_INSIGHT_ENV=development
ADAPTIX_INSIGHT_LOG_LEVEL=INFO

# Authentication & Security
ADAPTIX_INSIGHT_DEV_SECRET=adaptix-insight-dev-secret
ADAPTIX_INSIGHT_ALLOW_DEV_AUTH=true
ADAPTIX_INSIGHT_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# CORS Configuration
ADAPTIX_INSIGHT_CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3002

# Database Configuration
ADAPTIX_INSIGHT_DATABASE_URL=postgresql+asyncpg://insight:insight@localhost:5432/adaptix_insight
ADAPTIX_INSIGHT_DATABASE_URL_SYNC=postgresql://insight:insight@localhost:5432/adaptix_insight
ADAPTIX_INSIGHT_DATABASE_POOL_SIZE=20
ADAPTIX_INSIGHT_DATABASE_MAX_OVERFLOW=10

# Observability
ADAPTIX_INSIGHT_ENABLE_TRACING=false
ADAPTIX_INSIGHT_TRACE_EXPORTER_ENDPOINT=

# Data Retention (days)
ADAPTIX_INSIGHT_RAW_DATA_RETENTION_DAYS=730
ADAPTIX_INSIGHT_AGGREGATED_DATA_RETENTION_DAYS=2555
ADAPTIX_INSIGHT_AUDIT_LOG_RETENTION_DAYS=2555

# Feature Flags
ADAPTIX_INSIGHT_ENABLE_REAL_TIME_AGGREGATION=false
ADAPTIX_INSIGHT_ENABLE_AI_INSIGHTS=false